# Email (if you use nodemailer)
# ---------------------------
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# ---------------------------
# Other Config
# ---------------------------
BASE_URL=http://localhost:3000

# ---------------------------
# JWT
# ---------------------------
JWT_SECRET=your-jwt-secret-goes-here
