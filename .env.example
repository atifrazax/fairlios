# ---------------------------
# App Environment
# ---------------------------
PORT=3000

# ---------------------------
# Security
# ---------------------------
SESSION_SECRET=your-session-secret-goes-here

# ---------------------------
# Database
# ---------------------------
MONGO_URI=mongodb://localhost:27017/fairlios

